{
  "name": "archivo",
  "version": "1.1.0",
  "description": "Hard Disk Catalog",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --arm64",
    "build:mac-universal": "electron-builder --mac --universal",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.justedit.archivo",
    "productName": "archivo",
    "copyright": "Copyright \u00a9 2026 just edit",
    "files": [
      "src/**/*",
      "src/fonts/**/*",
      "src/assets/**/*",
      "build/icon.icns",
      "build/icon.ico",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "archivo 1.1.0",
      "icon": null,
      "internetEnabled": false,
      "writeUpdateInfo": false,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "archivo",
      "license": "LICENSE.txt"
    },
    "extraResources": [
      {
        "from": "LICENSE",
        "to": "LICENSE"
      }
    ]
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {},
  "author": "just edit",
  "license": "GPL-3.0-or-later"
}